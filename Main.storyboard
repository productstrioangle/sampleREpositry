<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="20037" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES" initialViewController="navController">
  <device id="retina6_1" orientation="portrait" appearance="light"/>
  <dependencies>
    <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="20020"/>
    <capability name="Safe area layout guides" minToolsVersion="9.0"/>
    <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
  </dependencies>
  <scenes>
    <!-- Navigation Controller -->
    <scene sceneID="navScene">
      <objects>
        <navigationController id="navController" sceneMemberID="viewController">
          <navigationBar key="navigationBar" contentMode="scaleToFill" id="navBar"/>
          <connections>
            <segue destination="restaurantDetailVC" kind="relationship" relationship="rootViewController" id="rootSegue"/>
          </connections>
        </navigationController>
        <placeholder placeholderIdentifier="IBFirstResponder" id="navFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
      </objects>
      <point key="canvasLocation" x="-1000" y="0"/>
    </scene>

    <!-- Restaurant Detail -->
    <scene sceneID="restaurantDetailScene">
      <objects>
        <viewController id="restaurantDetailVC" customClass="RestaurantDetailViewController" customModuleProvider="target" sceneMemberID="viewController">
          <view key="view" contentMode="scaleToFill" id="restaurantDetailView" userLabel="RestaurantDetailRoot">
            <rect key="frame" x="0.0" y="0.0" width="414" height="896"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
              <imageView userLabel="HeroImage" contentMode="scaleAspectFill" translatesAutoresizingMaskIntoConstraints="NO" id="heroImage">
                <rect key="frame" x="0" y="88" width="414" height="240"/>
                <color key="backgroundColor" red="0.9" green="0.9" blue="0.9" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
              </imageView>
              <label userLabel="TitleLabel" opaque="NO" contentMode="left" text="Don Giovannis Goodfellas" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" translatesAutoresizingMaskIntoConstraints="NO" id="titleLabel">
                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="26"/>
                <color key="textColor" cocoaTouchSystemColor="labelColor"/>
              </label>
              <label userLabel="SubtitleLabel" opaque="NO" contentMode="left" text="A family Italian restaurant that fuses Thai, Italian and Chinese cuisine with casual vibes." textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="0" translatesAutoresizingMaskIntoConstraints="NO" id="subtitleLabel">
                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                <color key="textColor" cocoaTouchSystemColor="secondaryLabelColor"/>
              </label>
              <stackView userLabel="ActionsStack" axis="horizontal" distribution="fillEqually" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="actionsStack">
                <subviews>
                  <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="callButton">
                    <state key="normal" title="Call"/>
                  </button>
                  <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="websiteButton">
                    <state key="normal" title="Website"/>
                  </button>
                  <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="mapButton">
                    <state key="normal" title="Map"/>
                  </button>
                </subviews>
              </stackView>
              <button userLabel="BookTableButton" opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="bookButton">
                <color key="backgroundColor" red="0.1" green="0.12" blue="0.16" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                <constraints>
                  <constraint firstAttribute="height" constant="56" id="bookButtonHeight"/>
                </constraints>
                <state key="normal" title="Book Table">
                  <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </state>
                <userDefinedRuntimeAttributes>
                  <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                    <integer key="value" value="12"/>
                  </userDefinedRuntimeAttribute>
                  <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                </userDefinedRuntimeAttributes>
                <connections>
                  <segue destination="bookingFormVC" kind="show" id="toBookingFormSegue"/>
                </connections>
              </button>
            </subviews>
            <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
            <constraints>
              <constraint firstItem="heroImage" firstAttribute="top" secondItem="restaurantDetailView.safeArea" secondAttribute="top" id="c1"/>
              <constraint firstItem="heroImage" firstAttribute="leading" secondItem="restaurantDetailView" secondAttribute="leading" id="c2"/>
              <constraint firstAttribute="trailing" secondItem="heroImage" secondAttribute="trailing" id="c3"/>
              <constraint firstItem="heroImage" firstAttribute="height" constant="240" id="c4"/>

              <constraint firstItem="titleLabel" firstAttribute="top" secondItem="heroImage" secondAttribute="bottom" constant="16" id="c5"/>
              <constraint firstItem="titleLabel" firstAttribute="leading" secondItem="restaurantDetailView" secondAttribute="leading" constant="24" id="c6"/>
              <constraint firstAttribute="trailing" secondItem="titleLabel" secondAttribute="trailing" constant="24" id="c7"/>

              <constraint firstItem="subtitleLabel" firstAttribute="top" secondItem="titleLabel" secondAttribute="bottom" constant="8" id="c8"/>
              <constraint firstItem="subtitleLabel" firstAttribute="leading" secondItem="titleLabel" secondAttribute="leading" id="c9"/>
              <constraint firstAttribute="trailing" secondItem="subtitleLabel" secondAttribute="trailing" constant="24" id="c10"/>

              <constraint firstItem="actionsStack" firstAttribute="top" secondItem="subtitleLabel" secondAttribute="bottom" constant="16" id="c11"/>
              <constraint firstItem="actionsStack" firstAttribute="leading" secondItem="restaurantDetailView" secondAttribute="leading" constant="24" id="c12"/>
              <constraint firstAttribute="trailing" secondItem="actionsStack" secondAttribute="trailing" constant="24" id="c13"/>

              <constraint firstItem="bookButton" firstAttribute="leading" secondItem="restaurantDetailView" secondAttribute="leading" constant="24" id="c14"/>
              <constraint firstAttribute="trailing" secondItem="bookButton" secondAttribute="trailing" constant="24" id="c15"/>
              <constraint firstItem="restaurantDetailView.safeArea" firstAttribute="bottom" secondItem="bookButton" secondAttribute="bottom" constant="16" id="c16"/>
              <constraint firstItem="bookButton" firstAttribute="top" relation="greaterThanOrEqual" secondItem="actionsStack" secondAttribute="bottom" constant="24" id="c17"/>
            </constraints>
            <viewLayoutGuide key="safeArea" id="restaurantDetailView.safeArea"/>
          </view>
          <navigationItem key="navigationItem" title="Restaurant" id="rdNavItem"/>
        </viewController>
        <placeholder placeholderIdentifier="IBFirstResponder" id="restaurantDetailFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
      </objects>
      <point key="canvasLocation" x="-350" y="0"/>
    </scene>

    <!-- Booking Form -->
    <scene sceneID="bookingFormScene">
      <objects>
        <viewController id="bookingFormVC" customClass="BookingFormViewController" customModuleProvider="target" sceneMemberID="viewController">
          <view key="view" contentMode="scaleToFill" id="bookingFormView" userLabel="BookingFormRoot">
            <rect key="frame" x="0.0" y="0.0" width="414" height="896"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
              <label userLabel="HeaderLabel" text="Book a table" translatesAutoresizingMaskIntoConstraints="NO" id="bfHeader">
                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="24"/>
                <color key="textColor" cocoaTouchSystemColor="labelColor"/>
              </label>
              <label userLabel="WhenLabel" text="When do you want to visit this place?" translatesAutoresizingMaskIntoConstraints="NO" id="bfWhenLabel">
                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                <color key="textColor" cocoaTouchSystemColor="secondaryLabelColor"/>
              </label>
              <stackView userLabel="PickersStack" axis="vertical" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="bfPickersStack">
                <subviews>
                  <button userLabel="ReservationButton" translatesAutoresizingMaskIntoConstraints="NO" id="reservationButton">
                    <state key="normal" title="Reservation"/>
                    <userDefinedRuntimeAttributes>
                      <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                        <integer key="value" value="12"/>
                      </userDefinedRuntimeAttribute>
                      <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                    <connections>
                      <segue destination="datePickerVC" kind="show" id="toDatePickerSegue"/>
                    </connections>
                  </button>
                  <button userLabel="TimeButton" translatesAutoresizingMaskIntoConstraints="NO" id="timeButton">
                    <state key="normal" title="Time"/>
                    <userDefinedRuntimeAttributes>
                      <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                        <integer key="value" value="12"/>
                      </userDefinedRuntimeAttribute>
                      <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                    <connections>
                      <segue destination="timePickerVC" kind="show" id="toTimePickerSegue"/>
                    </connections>
                  </button>
                </subviews>
              </stackView>

              <label userLabel="PeopleLabel" text="How many people?" translatesAutoresizingMaskIntoConstraints="NO" id="peopleLabel">
                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                <color key="textColor" cocoaTouchSystemColor="secondaryLabelColor"/>
              </label>
              <stackView userLabel="PeopleStack" axis="horizontal" alignment="center" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="peopleStack">
                <subviews>
                  <stepper id="peopleStepper" value="2" minimumValue="1" maximumValue="10" translatesAutoresizingMaskIntoConstraints="NO"/>
                  <label id="peopleCountLabel" text="2 Person" translatesAutoresizingMaskIntoConstraints="NO">
                    <fontDescription key="fontDescription" type="system" pointSize="16"/>
                    <color key="textColor" cocoaTouchSystemColor="labelColor"/>
                  </label>
                </subviews>
              </stackView>

              <button userLabel="ReserveButton" translatesAutoresizingMaskIntoConstraints="NO" id="reserveButton">
                <color key="backgroundColor" red="0.1" green="0.12" blue="0.16" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                <constraints>
                  <constraint firstAttribute="height" constant="56" id="reserveButtonHeight"/>
                </constraints>
                <state key="normal" title="Reserve">
                  <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </state>
                <userDefinedRuntimeAttributes>
                  <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                    <integer key="value" value="12"/>
                  </userDefinedRuntimeAttribute>
                  <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                </userDefinedRuntimeAttributes>
              </button>
            </subviews>
            <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
            <constraints>
              <constraint firstItem="bfHeader" firstAttribute="top" secondItem="bookingFormView.safeArea" secondAttribute="top" constant="16" id="bf1"/>
              <constraint firstItem="bfHeader" firstAttribute="leading" secondItem="bookingFormView" secondAttribute="leading" constant="24" id="bf2"/>
              <constraint firstAttribute="trailing" secondItem="bfHeader" secondAttribute="trailing" constant="24" id="bf3"/>

              <constraint firstItem="bfWhenLabel" firstAttribute="top" secondItem="bfHeader" secondAttribute="bottom" constant="8" id="bf4"/>
              <constraint firstItem="bfWhenLabel" firstAttribute="leading" secondItem="bfHeader" secondAttribute="leading" id="bf5"/>
              <constraint firstAttribute="trailing" secondItem="bfWhenLabel" secondAttribute="trailing" constant="24" id="bf6"/>

              <constraint firstItem="bfPickersStack" firstAttribute="top" secondItem="bfWhenLabel" secondAttribute="bottom" constant="16" id="bf7"/>
              <constraint firstItem="bfPickersStack" firstAttribute="leading" secondItem="bookingFormView" secondAttribute="leading" constant="24" id="bf8"/>
              <constraint firstAttribute="trailing" secondItem="bfPickersStack" secondAttribute="trailing" constant="24" id="bf9"/>

              <constraint firstItem="peopleLabel" firstAttribute="top" secondItem="bfPickersStack" secondAttribute="bottom" constant="24" id="bf10"/>
              <constraint firstItem="peopleLabel" firstAttribute="leading" secondItem="bfPickersStack" secondAttribute="leading" id="bf11"/>
              <constraint firstAttribute="trailing" secondItem="peopleLabel" secondAttribute="trailing" constant="24" id="bf12"/>

              <constraint firstItem="peopleStack" firstAttribute="top" secondItem="peopleLabel" secondAttribute="bottom" constant="8" id="bf13"/>
              <constraint firstItem="peopleStack" firstAttribute="leading" secondItem="peopleLabel" secondAttribute="leading" id="bf14"/>

              <constraint firstItem="reserveButton" firstAttribute="leading" secondItem="bookingFormView" secondAttribute="leading" constant="24" id="bf15"/>
              <constraint firstAttribute="trailing" secondItem="reserveButton" secondAttribute="trailing" constant="24" id="bf16"/>
              <constraint firstItem="bookingFormView.safeArea" firstAttribute="bottom" secondItem="reserveButton" secondAttribute="bottom" constant="16" id="bf17"/>
            </constraints>
            <viewLayoutGuide key="safeArea" id="bookingFormView.safeArea"/>
          </view>
          <navigationItem key="navigationItem" title="Book a table" id="bfNavItem"/>
        </viewController>
        <placeholder placeholderIdentifier="IBFirstResponder" id="bookingFormFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
      </objects>
      <point key="canvasLocation" x="350" y="0"/>
    </scene>

    <!-- Date Picker -->
    <scene sceneID="datePickerScene">
      <objects>
        <viewController id="datePickerVC" customClass="DatePickerViewController" customModuleProvider="target" sceneMemberID="viewController">
          <view key="view" contentMode="scaleToFill" id="datePickerView" userLabel="DatePickerRoot">
            <rect key="frame" x="0.0" y="0.0" width="414" height="896"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
              <label userLabel="DateHeader" text="When do you want to visit this place?" translatesAutoresizingMaskIntoConstraints="NO" id="dpHeader">
                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="22"/>
                <color key="textColor" cocoaTouchSystemColor="labelColor"/>
              </label>
              <datePicker contentMode="scaleToFill" datePickerMode="date" translatesAutoresizingMaskIntoConstraints="NO" id="datePicker">
                <rect key="frame" x="0" y="0" width="414" height="300"/>
              </datePicker>
            </subviews>
            <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
            <constraints>
              <constraint firstItem="dpHeader" firstAttribute="top" secondItem="datePickerView.safeArea" secondAttribute="top" constant="16" id="dp1"/>
              <constraint firstItem="dpHeader" firstAttribute="leading" secondItem="datePickerView" secondAttribute="leading" constant="24" id="dp2"/>
              <constraint firstAttribute="trailing" secondItem="dpHeader" secondAttribute="trailing" constant="24" id="dp3"/>

              <constraint firstItem="datePicker" firstAttribute="top" secondItem="dpHeader" secondAttribute="bottom" constant="16" id="dp4"/>
              <constraint firstItem="datePicker" firstAttribute="leading" secondItem="dpHeader" secondAttribute="leading" id="dp5"/>
              <constraint firstAttribute="trailing" secondItem="datePicker" secondAttribute="trailing" constant="24" id="dp6"/>
            </constraints>
            <viewLayoutGuide key="safeArea" id="datePickerView.safeArea"/>
          </view>
          <navigationItem key="navigationItem" title="Reservation" id="dpNavItem"/>
        </viewController>
        <placeholder placeholderIdentifier="IBFirstResponder" id="datePickerFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
      </objects>
      <point key="canvasLocation" x="1050" y="0"/>
    </scene>

    <!-- Time Picker -->
    <scene sceneID="timePickerScene">
      <objects>
        <viewController id="timePickerVC" customClass="TimePickerViewController" customModuleProvider="target" sceneMemberID="viewController">
          <view key="view" contentMode="scaleToFill" id="timePickerView" userLabel="TimePickerRoot">
            <rect key="frame" x="0.0" y="0.0" width="414" height="896"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
              <label userLabel="TimeHeader" text="Time" translatesAutoresizingMaskIntoConstraints="NO" id="tpHeader">
                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="22"/>
                <color key="textColor" cocoaTouchSystemColor="labelColor"/>
              </label>
              <tableView clipsSubviews="YES" alwaysBounceVertical="YES" dataMode="prototypes" style="insetGrouped" separatorStyle="default" translatesAutoresizingMaskIntoConstraints="NO" id="timeTable">
                <color key="backgroundColor" cocoaTouchSystemColor="systemBackgroundColor"/>
                <prototypes>
                  <tableViewCell id="timeCell" userLabel="TimeCell" style="IBUITableViewCellStyleDefault" reuseIdentifier="TimeCell" textLabel="timeCellLabel">
                    <rect key="frame" x="0.0" y="0.0" width="320" height="44"/>
                    <tableViewCellContentView key="contentView" id="timeCellContent">
                      <subviews>
                        <label id="timeCellLabel" text="8:00 AM - 12:00 PM" translatesAutoresizingMaskIntoConstraints="NO">
                          <fontDescription key="fontDescription" type="system" pointSize="16"/>
                          <color key="textColor" cocoaTouchSystemColor="labelColor"/>
                        </label>
                      </subviews>
                      <constraints>
                        <constraint firstItem="timeCellLabel" firstAttribute="leading" secondItem="timeCellContent" secondAttribute="leading" constant="16" id="tc1"/>
                        <constraint firstAttribute="trailing" secondItem="timeCellLabel" secondAttribute="trailing" constant="16" id="tc2"/>
                        <constraint firstItem="timeCellLabel" firstAttribute="centerY" secondItem="timeCellContent" secondAttribute="centerY" id="tc3"/>
                      </constraints>
                    </tableViewCellContentView>
                  </tableViewCell>
                </prototypes>
              </tableView>
              <button userLabel="SetTimeButton" translatesAutoresizingMaskIntoConstraints="NO" id="setTimeButton">
                <color key="backgroundColor" red="0.1" green="0.12" blue="0.16" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                <constraints>
                  <constraint firstAttribute="height" constant="56" id="setTimeButtonHeight"/>
                </constraints>
                <state key="normal" title="Set Time">
                  <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </state>
                <userDefinedRuntimeAttributes>
                  <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                    <integer key="value" value="12"/>
                  </userDefinedRuntimeAttribute>
                  <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                </userDefinedRuntimeAttributes>
              </button>
            </subviews>
            <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
            <constraints>
              <constraint firstItem="tpHeader" firstAttribute="top" secondItem="timePickerView.safeArea" secondAttribute="top" constant="16" id="tp1"/>
              <constraint firstItem="tpHeader" firstAttribute="leading" secondItem="timePickerView" secondAttribute="leading" constant="24" id="tp2"/>
              <constraint firstAttribute="trailing" secondItem="tpHeader" secondAttribute="trailing" constant="24" id="tp3"/>

              <constraint firstItem="timeTable" firstAttribute="top" secondItem="tpHeader" secondAttribute="bottom" constant="12" id="tp4"/>
              <constraint firstItem="timeTable" firstAttribute="leading" secondItem="timePickerView" secondAttribute="leading" id="tp5"/>
              <constraint firstAttribute="trailing" secondItem="timeTable" secondAttribute="trailing" id="tp6"/>
              <constraint firstItem="setTimeButton" firstAttribute="top" secondItem="timeTable" secondAttribute="bottom" constant="12" id="tp7"/>

              <constraint firstItem="setTimeButton" firstAttribute="leading" secondItem="timePickerView" secondAttribute="leading" constant="24" id="tp8"/>
              <constraint firstAttribute="trailing" secondItem="setTimeButton" secondAttribute="trailing" constant="24" id="tp9"/>
              <constraint firstItem="timePickerView.safeArea" firstAttribute="bottom" secondItem="setTimeButton" secondAttribute="bottom" constant="16" id="tp10"/>
            </constraints>
            <viewLayoutGuide key="safeArea" id="timePickerView.safeArea"/>
          </view>
          <navigationItem key="navigationItem" title="Time" id="tpNavItem"/>
        </viewController>
        <placeholder placeholderIdentifier="IBFirstResponder" id="timePickerFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
      </objects>
      <point key="canvasLocation" x="1750" y="0"/>
    </scene>
  </scenes>
</document>